# Google account for Schoolity login
GOOGLE_EMAIL=your-email@gmail.com

# Gmail App Password (generate at https://myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipients (comma-separated)
DIGEST_TO=parent1@gmail.com,parent2@gmail.com

# Student info (shown in email subject/header)
STUDENT_NAME=Förnamn Efternamn
SCHOOL_NAME=Skolans Namn
CLASS_NAME=Klass X

# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
